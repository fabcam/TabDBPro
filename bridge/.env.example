# ─────────────────────────────────────────────────────────────
# OPTION A: Multiple named connections (recommended)
# Set CONNECTIONS to a JSON array. DB_* vars below are ignored.
# ─────────────────────────────────────────────────────────────
# CONNECTIONS=[{"name":"Local MySQL","type":"mysql","host":"localhost","port":3306,"database":"mydb","user":"root","password":""},{"name":"Local Postgres","type":"postgres","host":"localhost","port":5432,"database":"mydb","user":"postgres","password":""}]

# Each connection supports:
#   name     (required) display name shown in the UI
#   type     (required) "mysql" or "postgres"
#   host     default: localhost
#   port     default: 3306 (mysql) / 5432 (postgres)
#   database default schema/database to open
#   user     DB username
#   password DB password
#   url      full connection string (overrides host/port/database/user/password)
#   ssh      optional — SSH tunnel config (see below)

# ─────────────────────────────────────────────────────────────
# SSH tunnel (planned — not yet implemented)
# Add an "ssh" block to any connection to reach remote databases.
# The bridge opens an SSH tunnel and connects through it;
# the DB host/port are resolved from the remote server's perspective.
#
# Example — single remote Postgres behind a bastion:
#
# CONNECTIONS=[{
#   "name": "Staging Postgres",
#   "type": "postgres",
#   "host": "db.internal",
#   "port": 5432,
#   "database": "staging",
#   "user": "app",
#   "password": "",
#   "ssh": {
#     "host": "bastion.example.com",
#     "port": 22,
#     "user": "deploy",
#     "privateKeyPath": "~/.ssh/id_ed25519"
#   }
# }]
#
# The private key must already be trusted by the remote SSH server.
# The SSH host must exist in your ~/.ssh/known_hosts — the bridge
# will refuse to connect to unknown hosts (no auto-accept).
#
# SSH block fields:
#   host           (required) SSH server hostname or IP
#   port           default: 22
#   user           (required) SSH login username
#   privateKeyPath (required) path to private key; ~ is expanded
#   passphrase     passphrase if the key is encrypted, otherwise omit
#   knownHostsPath default: ~/.ssh/known_hosts
# ─────────────────────────────────────────────────────────────

# ─────────────────────────────────────────────────────────────
# OPTION B: Single connection (no connection selector in UI)
# Used when CONNECTIONS is not set.
# ─────────────────────────────────────────────────────────────
DB_TYPE=mysql
DB_HOST=localhost
DB_PORT=3306
DB_NAME=mydb
DB_USER=root
DB_PASSWORD=

# Bridge port (default: 47321)
# BRIDGE_PORT=47321

# Set to "false" to allow write queries (INSERT/UPDATE/DELETE/...)
# Default is true — strongly recommended to keep enabled
# READ_ONLY=true
