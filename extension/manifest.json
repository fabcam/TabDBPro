{
  "manifest_version": 3,
  "name": "TabDB Pro",
  "version": "0.1.0",
  "description": "Query, browse and edit your database directly from Chrome DevTools",
  "icons": {
    "48": "icons/icon-48.png"
  },
  "devtools_page": "devtools/devtools.html",
  "permissions": ["storage"],
  "host_permissions": [
    "http://127.0.0.1:47321/*"
  ]
}
